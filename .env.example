# Copy this file to .env and fill in real values before running the app.
# Never commit your real .env file.

# Flask session signing key — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_this_to_a_random_secret

# Key used to encrypt each user's mail app-password before storing it in SQLite.
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=change_this_to_a_generated_fernet_key

# Mail server settings (defaults work for Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
